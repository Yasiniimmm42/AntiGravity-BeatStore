generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum LicenseType {
  BASIC
  PREMIUM
  UNLIMITED
}

model Beat {
  id             Int         @id @default(autoincrement())
  slug           String      @unique
  title          String
  genre          String
  bpm            Int
  taggedAudioUrl String?
  coverUrl       String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  licenses       License[]
  orderItems     OrderItem[]
}

model License {
  id        Int         @id @default(autoincrement())
  beatId    Int
  beat      Beat        @relation(fields: [beatId], references: [id], onDelete: Cascade)
  type      LicenseType
  price     Float
  fileUrl   String
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@unique([beatId, type])
}

model Order {
  id            Int         @id @default(autoincrement())
  orderNumber   String      @unique
  customerEmail String
  customerName  String?
  total         Float
  status        String      @default("paid")
  items         OrderItem[]
  createdAt     DateTime    @default(now())
}

model OrderItem {
  id          Int         @id @default(autoincrement())
  orderId     Int
  order       Order       @relation(fields: [orderId], references: [id])
  beatId      Int
  beat        Beat        @relation(fields: [beatId], references: [id])
  licenseType LicenseType
  title       String
  price       Float
  downloadUrl String
}

// Önizleme akışı için kısa ömürlü, tek kullanımlık erişim token'ı.
// Çoklu instance/yatay ölçeklenebilirlik için RAM yerine veritabanında saklanır.
model PreviewToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  filename  String
  isUsed    Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

// /api/admin/login brute-force koruması için IP başına deneme sayacı.
model RateLimit {
  id      Int      @id @default(autoincrement())
  key     String   @unique
  count   Int      @default(0)
  resetAt DateTime
}
